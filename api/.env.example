# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4338
# Comma-separated allowed origins for CORS (Next.js dev + prod)
CORS_ORIGINS=http://localhost:3000,https://predict-intelligence-ui.vercel.app

# ─── SQLite database path ─────────────────────────────────────────────────────
# Single-file SQLite database — no external database required
DB_FILE=./data/store.db

# ─── Source display config (for /perceive endpoint) ──────────────────────────
GRAPHITI_URL=http://localhost:8000
POLYMARKET_FETCH_LIMIT=200
