# ─── LiteLLM ─────────────────────────────────────────────────────────────────
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://your-litellm-proxy.com/v1
LITELLM_MODEL=gpt-4o-mini

# ─── Graphiti knowledge graph ────────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict

# ─── A2A server ───────────────────────────────────────────────────────────────
PORT=4337
BASE_URL=http://localhost:4337

# ─── api/ module (data hub) ───────────────────────────────────────────────────
# When set, positions and audit logs are dual-written to the api/ SQLite store.
# Omit to use local file-only mode (shared data/ volume).
API_URL=http://localhost:4338

# ─── Local file fallback paths (also used when API_URL is unset) ─────────────
PROFILES_DIR=../data/profiles
POSITIONS_DIR=../data/positions
AUDIT_DIR=../data/audit
MARKET_REGISTRY_FILE=../data/market_registry.json

# ─── Fallback wallet (used when no ENS profile is loaded) ────────────────────
AGENT_WALLET_ADDRESS=0x...

# ─── Daily cycle ──────────────────────────────────────────────────────────────
CYCLE_INTERVAL_MS=86400000
DRY_RUN=true
