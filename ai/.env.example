# ─── LiteLLM ─────────────────────────────────────────────────────────────────
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://your-litellm-proxy.com/v1
LITELLM_MODEL=gpt-4o-mini

# ─── Graphiti knowledge graph ────────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict

# ─── A2A server ───────────────────────────────────────────────────────────────
PORT=4337
BASE_URL=http://localhost:4337

# ─── api/ module (data hub) ───────────────────────────────────────────────────
# When set, positions and audit logs are dual-written to the api/ SQLite store.
# Omit to use local file-only mode (shared data/ volume).
API_URL=http://localhost:4338

# ─── Local file fallback paths (also used when API_URL is unset) ─────────────
PROFILES_DIR=../data/profiles
POSITIONS_DIR=../data/positions
AUDIT_DIR=../data/audit
MARKET_REGISTRY_FILE=../data/market_registry.json

# ─── Agent trading wallet ────────────────────────────────────────────────────
# Must be the public address derived from AGENT_PRIVATE_KEY below.
AGENT_WALLET_ADDRESS=0x...
# Private key of the agent's Sepolia wallet (no 0x prefix).
# Required for live on-chain swaps (ignored in quote-only mode when key is absent).
AGENT_PRIVATE_KEY=

# ─── Uniswap Trading API ──────────────────────────────────────────────────────
# Get a key at https://developers.uniswap.org/dashboard/ — free tier available.
# When set, the agent routes "swap" decisions through the Uniswap Trading API
# (quote → sign permit2 → broadcast via Universal Router) on Sepolia testnet.
# Without this key the swap executor falls back to a no-op stub.
UNISWAP_API_KEY=

# Chain ID to use for Uniswap swaps (default: 11155111 = Sepolia testnet).
UNISWAP_CHAIN_ID=11155111

# Override the Uniswap Trading API base URL (default: https://trade-api.gateway.uniswap.org/v1).
UNISWAP_API_BASE=https://trade-api.gateway.uniswap.org/v1

# Override the DexScreener base URL used for mainnet reference price lookups (default: https://api.dexscreener.com).
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# Reliable Sepolia RPC — Alchemy or Infura recommended.
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ─── Daily cycle ──────────────────────────────────────────────────────────────
CYCLE_INTERVAL_MS=86400000
DRY_RUN=true
