# ─── AI agent (A2A server) ────────────────────────────────────────────────────
AGENT_A2A_URL=http://localhost:4337
WORKFLOW_API_KEY=

# ─── Graphiti (alpha ingestion) ───────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict
