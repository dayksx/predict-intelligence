# ─── Listener ────────────────────────────────────────────────────────────────
INTERVAL_HOURS=24
MARKET_CATEGORIES=crypto,finance,geopolitics,energy,sports

# ─── Graphiti server ──────────────────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict

# ─── Polymarket ───────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_FETCH_LIMIT=50

# ─── Graphiti server config (used by docker-compose.yml) ─────────────────────
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://your-litellm-proxy.com/v1
LITELLM_MODEL=gpt-4o-mini
LITELLM_EMBEDDING_MODEL=titan-embed-text-v2
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
