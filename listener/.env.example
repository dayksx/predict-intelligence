# ─── Listener ────────────────────────────────────────────────────────────────
INTERVAL_HOURS=24
MARKET_CATEGORIES=crypto,finance,geopolitics,energy,sports

# ─── Graphiti server ──────────────────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict

# ─── Polymarket ───────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_FETCH_LIMIT=50

# ─── api/ module (data hub) ───────────────────────────────────────────────────
# When set, markets and profiles are dual-written to the api/ SQLite store.
# Omit to use local file-only mode (shared data/ volume).
API_URL=http://localhost:4338

# ─── Local file fallback paths (also used when API_URL is unset) ─────────────
MARKET_REGISTRY_FILE=../data/market_registry.json

# ─── Graphiti server config (used by docker-compose.yml) ─────────────────────
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://your-litellm-proxy.com/v1
LITELLM_MODEL=gpt-4o-mini
LITELLM_EMBEDDING_MODEL=titan-embed-text-v2
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── ENS user registration listener ──────────────────────────────────────────
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ENS_SUBGRAPH_URL=https://api.studio.thegraph.com/query/49574/enssepolia/version/latest
PROFILES_DIR=../data/profiles
ENS_POLL_INTERVAL_MS=60000
ETH_USD_ESTIMATE=3000
# Hard cap on max position size in USDC — useful for testing (e.g. 2 = max $2 per trade).
# Remove or leave blank to use the full delegated-amount-based sizing.
MAX_POSITION_USDC=2
DRY_RUN=true
