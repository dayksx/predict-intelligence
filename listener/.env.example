# ─── Listener ────────────────────────────────────────────────────────────────
INTERVAL_HOURS=24
MARKET_CATEGORIES=crypto,finance,geopolitics,energy,sports

# ─── Graphiti server ──────────────────────────────────────────────────────────
GRAPHITI_URL=http://localhost:8000
GRAPHITI_GROUP_ID=predict

# ─── Polymarket ───────────────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_FETCH_LIMIT=50

# ─── Market registry (shared with ai module) ─────────────────────────────────
# Path to the JSON file that maps market_id → CLOB token IDs and neg_risk.
# Both listener (writes) and ai (reads) must point to the same file.
MARKET_REGISTRY_FILE=../data/market_registry.json

# ─── Graphiti server config (used by docker-compose.yml) ─────────────────────
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://your-litellm-proxy.com/v1
LITELLM_MODEL=gpt-4o-mini
LITELLM_EMBEDDING_MODEL=titan-embed-text-v2
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── ENS user registration listener ──────────────────────────────────────────
# Sepolia RPC for viem text record resolution (use Alchemy/Infura for reliability)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
# ENS Sepolia subgraph endpoint (The Graph Studio)
ENS_SUBGRAPH_URL=https://api.studio.thegraph.com/query/49574/enssepolia/version/latest
# Where to write per-user TradingStrategy JSON files (must match ai module PROFILES_DIR)
PROFILES_DIR=../data/profiles
# How often to poll for new registrations (milliseconds, default 1 min)
ENS_POLL_INTERVAL_MS=60000
# ETH/USD estimate used for position sizing (update as needed)
ETH_USD_ESTIMATE=3000
# Set to "false" to enable live trading in the AI module
DRY_RUN=true
