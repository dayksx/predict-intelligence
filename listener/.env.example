# ─── listener service environment ────────────────────────────────────────────
# Copy to listener/.env and fill in real values before running.
# Run: cd listener && cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# How often the tick runs in hours. Default: 24.
INTERVAL_HOURS=24

# ─── Knowledge Graph (Neo4j / FalkorDB) ──────────────────────────────────────
# Must point to the same instance as the ai service
GRAPHITI_NEO4J_URI=bolt://localhost:7687
GRAPHITI_NEO4J_USER=neo4j
GRAPHITI_NEO4J_PASSWORD=password
GRAPHITI_GROUP_PREFIX=predict

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Used to generate node embeddings when writing to the knowledge graph
OPENAI_API_KEY=sk-...

# ─── Market data ──────────────────────────────────────────────────────────────
# Read-only — always Polymarket mainnet Gamma API (no testnet key needed)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# ─── Snapshot output ──────────────────────────────────────────────────────────
# Directory where market snapshots are written; ai service reads from the same path
SNAPSHOT_DIR=/tmp/predict_snapshots

# ─── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
