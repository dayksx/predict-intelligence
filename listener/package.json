{
  "name": "predict-intelligence-listener",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "dev:market": "tsx src/run-market-tick.ts",
    "dev:ens": "tsx src/run-ens-tick.ts",
    "dev:ens:reset": "tsx src/run-ens-tick.ts -- --reset-timestamp",
    "typecheck": "tsc --noEmit",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f graphiti"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^4.4.0",
    "neo4j-driver": "^5.28.0",
    "openai": "^4.86.0",
    "uuid": "^11.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
